# Copy this file to .env for local development.
# Do not commit real secrets or environment-specific .env files.

# Application
APP_DOMAIN=fastapi.localhost
TRAEFIK_DASHBOARD_DOMAIN=dashboard-fastapi-traefik.example.com

# PostgreSQL
POSTGRES_USER=fastapi_traefik
POSTGRES_PASSWORD=change-me
POSTGRES_DB=fastapi_traefik

# Only needed when running the FastAPI app outside Docker Compose.
# Docker Compose builds DATABASE_URL from the PostgreSQL values above.
# DATABASE_URL=postgresql://fastapi_traefik:change-me@localhost:5432/fastapi_traefik

# Traefik dashboard basic auth for production.
# Generate with htpasswd, for example:
# htpasswd -nb testuser 'change-me'
TRAEFIK_DASHBOARD_AUTH=testuser:replace-with-htpasswd-hash

# Traefik Let's Encrypt email is currently configured in traefik.prod.toml.
# Update that file before production deployment.
